@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant "d:ListCommand" as ListCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("list")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("list")
activate AddressBookParser

alt#LightCoral #FFCCCC extra parameters provided
    AddressBookParser --> LogicManager : throw ParseException\n("list takes no parameters.")
end

create ListCommand
AddressBookParser -> ListCommand
activate ListCommand

ListCommand --> AddressBookParser
deactivate ListCommand

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> ListCommand : execute(m)
activate ListCommand

ListCommand -> Model : updateFilteredPersonList(PREDICATE_SHOW_ALL_PERSONS)
activate Model
note right
  Clears any active filter,
  find, or sort view; restores
  the full alphabetical list
end note
Model --> ListCommand
deactivate Model

ListCommand -> Model : getFilteredPersonList()
activate Model
Model --> ListCommand : currentList
deactivate Model

create CommandResult
ListCommand -> CommandResult
activate CommandResult
note right
  "Listed X candidates." or
  "No candidates found. Use
   the add command to add
   a new candidate."
end note
CommandResult --> ListCommand
deactivate CommandResult

ListCommand --> LogicManager : r
deactivate ListCommand

[<--LogicManager
deactivate LogicManager
@enduml
